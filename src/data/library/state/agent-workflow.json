            "$$mdtype": "Tag",
            "name": "Paragraph",
            "attributes": {},
            "children": [
              "Discover"
            ]
          }
        ],
        "state": "accent"
      }
    },
    {
      "id": "understand",
      "type": "state",
      "col": 1,
      "row": 0,
      "data": {
        "text": [
          {
            "$$mdtype": "Tag",
            "name": "Paragraph",
            "attributes": {},
            "children": [
              "Understand"
            ]
          }
        ],
        "state": "accent"
      }
    },
    {
      "id": "execute",
      "type": "state",
      "col": 1,
      "row": 1,
      "data": {
        "text": [
          {
            "$$mdtype": "Tag",
            "name": "Paragraph",
            "attributes": {},
            "children": [
              "Execute"
            ]
          }
        ],
        "state": "success"
      }
    },
    {
      "id": "compose",
      "type": "state",
      "col": 0,
