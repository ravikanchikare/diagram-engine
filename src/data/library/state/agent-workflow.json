    {
      "from": "discover",
      "to": "understand",
      "label": "inspect schema"
    },
    {
      "from": "understand",
      "to": "execute",
      "label": "run --json"
    },
    {
      "from": "execute",
      "to": "compose",
      "label": "format output"
    },
    {
      "from": "compose",
      "to": "discover",
      "label": "next task"
